{
	"name": "@bhsd/lezer-abusefilter",
	"version": "0.2.1",
	"description": "Lezer parser for MediaWiki extension AbuseFilter",
	"keywords": [
		"mediawiki",
		"lezer"
	],
	"homepage": "https://github.com/bhsd-harry/lezer-abusefilter#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/lezer-abusefilter/issues"
	},
	"license": "GPL-3.0-or-later",
	"files": [
		"dist/",
		"!dist/*.test.*",
		"!dist/gh-page.*",
		"analyzer/analyzer.*",
		"analyzer/ThirdPartyNotices"
	],
	"browser": "dist/index.js",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/lezer-abusefilter.git"
	},
	"scripts": {
		"prepublishOnly": "npm run build",
		"build:analyzer": "esbuild analyzer/index.ts --charset=utf8 --target=es2017 --bundle --format=esm --outfile=analyzer/analyzer.js && cp analyzer/analyzer.js build/",
		"build:parser": "lezer-generator src/abusefilter.grammar -o src/parser.js",
		"build:core": "tsc && cp src/parser.*js dist/",
		"build:gh-page": "esbuild src/gh-page.ts --charset=utf8 --bundle --format=esm --outdir=build && esbuild src/gh-page.ts --charset=utf8 --target=es2019 --bundle --format=esm --minify --sourcemap --outdir=.",
		"build:test": "rm -rf test/dist/; tsc --project test/tsconfig.json && npm test",
		"build": "npm run build:parser && npm run build:analyzer && npm run build:core",
		"lint:ts": "tsc --noEmit && eslint --cache .",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:md",
		"server": "npm run test:end; http-server .. -c-1 --cors -s &",
		"test": "mocha test/dist/test.js && mocha test/dist/analyzer.test.js",
		"test:real": "node test/dist/real.js",
		"test:end": "pkill -x http-server"
	},
	"dependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/lint": "^6.9.5"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^2.1.1",
		"@bhsd/nodejs": "^1.0.0",
		"@bhsd/test-util": "^0.4.0",
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.40.0",
		"@lezer/generator": "^1.8.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/mocha": "^10.0.10",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"esbuild": "^0.27.4",
		"eslint": "^9.39.4",
		"eslint-plugin-es-x": "^9.5.0",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-jsdoc": "^62.7.1",
		"eslint-plugin-jsonc": "^3.1.1",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-unicorn": "^63.0.0",
		"http-server": "^14.1.1",
		"markdownlint-cli2": "^0.21.0",
		"mocha": "^11.7.5",
		"typescript": "^5.9.3"
	}
}
