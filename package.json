{
	"name": "@bhsd/lezer-abusefilter",
	"version": "0.5.0",
	"description": "Lezer parser for MediaWiki extension AbuseFilter",
	"keywords": [
		"mediawiki",
		"lezer"
	],
	"homepage": "https://github.com/bhsd-harry/lezer-abusefilter#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/lezer-abusefilter/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"dist/",
		"analyzer/analyzer.*",
		"analyzer/ThirdPartyNotices"
	],
	"browser": "dist/index.js",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/lezer-abusefilter.git"
	},
	"scripts": {
		"ls": "npm i --package-lock-only && npm ls --package-lock-only --all --omit=dev",
		"prepublishOnly": "npm run build",
		"build:analyzer": "esbuild analyzer/index.ts --charset=utf8 --target=es2017 --bundle --format=esm --outfile=analyzer/analyzer.js && gsed -i '/^\\/\\/ /d' analyzer/analyzer.js && cp analyzer/analyzer.js build/",
		"build:parser": "lezer-generator src/abusefilter.grammar -o src/parser.js",
		"build:core": "tsc && cp src/parser.*js dist/",
		"build:test": "rm -rf test/dist/; tsc --project test/tsconfig.json && npm test",
		"build": "npm run build:parser && npm run build:analyzer && npm run build:core",
		"lint:ts": "tsc --noEmit && tsc --project analyzer/tsconfig.json && tsc --project test/tsconfig.json --noEmit && eslint --cache . && eslint --no-config-lookup -c eslint.dist.js --no-inline-config dist/*.js",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:md",
		"test": "testUtil test/dist/test.js test/dist/*.test.js",
		"test:real": "node test/dist/real.js"
	},
	"peerDependencies": {
		"@codemirror/language": "^6.0.0",
		"@codemirror/lint": "^6.0.0",
		"@codemirror/state": "^6.1.0",
		"@codemirror/view": "^6.0.0"
	},
	"peerDependenciesMeta": {
		"@codemirror/lint": {
			"optional": true
		},
		"@codemirror/state": {
			"optional": true
		}
	},
	"dependencies": {
		"@bhsd/browser": "^1.1.0",
		"@bhsd/cm-util": "^2.3.0"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^3.2.0",
		"@bhsd/nodejs": "^1.2.1",
		"@bhsd/test-util": "^3.1.0",
		"@codemirror/autocomplete": "^6.20.3",
		"@codemirror/language": "^6.12.4",
		"@codemirror/lint": "^6.9.7",
		"@codemirror/state": "^6.7.1",
		"@codemirror/view": "^6.43.6",
		"@lezer/generator": "^1.8.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.7.0",
		"markdownlint-cli2": "^0.23.1",
		"typescript": "^6.0.3"
	}
}
